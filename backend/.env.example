# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration
# Use MongoDB Atlas URI for production: mongodb+srv://user:password@cluster.mongodb.net/dbname
MONGODB_URI=mongodb://localhost:27017/feature-flags-db

# JWT Configuration
# Use a strong random secret in production (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRE=7d

# Super Admin Credentials (Static Login)
# Change these to strong credentials in production
SUPERADMIN_EMAIL=admin@system.com
SUPERADMIN_PASSWORD=SuperAdmin@123
